<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.unicauca.piedraazul.controller.PacientePanelController"
            style="-fx-background-color: #f4f6f8;">

    <left>
        <VBox spacing="15"
              prefWidth="240"
              style="-fx-background-color: #12324a;"
              BorderPane.alignment="CENTER">
            <padding>
                <Insets top="25" right="20" bottom="25" left="20"/>
            </padding>

            <Label text="PiedraAzul"
                   style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>

            <Label text="Panel Paciente"
                   style="-fx-text-fill: #d6e4ef; -fx-font-size: 15px;"/>

            <Separator/>

            <Label text="Agendamiento autónomo"
                   style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>

            <Label text="Consulta médicos, revisa franjas disponibles, agenda tu cita y consulta tu historial."
                   wrapText="true"
                   style="-fx-text-fill: #d6e4ef; -fx-font-size: 12px;"/>

            <Region minHeight="24" prefHeight="32" maxHeight="40"/>

            <Button text="Cerrar sesión"
                    maxWidth="Infinity"
                    onAction="#logout"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-height: 42;"/>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="20">
                    <padding>
                        <Insets top="25" right="35" bottom="35" left="35"/>
                    </padding>

                    <VBox spacing="5">
                        <Label text="Agendamiento autónomo de citas"
                               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1f2d3d;"/>

                        <Label text="Consulta tus datos personales, selecciona un médico/terapista, revisa disponibilidad, confirma tu cita y consulta tu historial."
                               wrapText="true"
                               style="-fx-font-size: 14px; -fx-text-fill: #5d6d7e;"/>
                    </VBox>

                    <VBox spacing="12"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 8, 0, 0, 2);">

                        <HBox spacing="12">
                            <VBox spacing="4">
                                <Label text="Datos del paciente"
                                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1f2d3d;"/>

                                <Label text="Estos datos pertenecen a su perfil. Para modificarlos use la opción Editar perfil."
                                       style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                            </VBox>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Button fx:id="btnEditarPerfil"
                                    text="Editar perfil"
                                    onAction="#editarPerfil"
                                    prefWidth="130"
                                    style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-weight: bold;"/>

                            <Button fx:id="btnGuardarPerfil"
                                    text="Guardar perfil"
                                    onAction="#guardarPerfil"
                                    prefWidth="130"
                                    disable="true"
                                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        </HBox>

                        <GridPane hgap="15" vgap="14">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="25"/>
                                <ColumnConstraints percentWidth="25"/>
                                <ColumnConstraints percentWidth="25"/>
                                <ColumnConstraints percentWidth="25"/>
                            </columnConstraints>

                            <Label text="Tipo documento *" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="cmbTipoDocumento"
                                      maxWidth="Infinity"
                                      GridPane.rowIndex="1"
                                      GridPane.columnIndex="0"/>

                            <Label text="Número documento *" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                            <TextField fx:id="txtNumeroDocumento"
                                       promptText="Ej: 1099999995"
                                       GridPane.rowIndex="1"
                                       GridPane.columnIndex="1"/>

                            <Label text="Nombres *" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <TextField fx:id="txtNombres"
                                       promptText="Ej: Daniela"
                                       GridPane.rowIndex="1"
                                       GridPane.columnIndex="2"/>

                            <Label text="Apellidos *" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
                            <TextField fx:id="txtApellidos"
                                       promptText="Ej: Muñoz"
                                       GridPane.rowIndex="1"
                                       GridPane.columnIndex="3"/>

                            <Label text="Celular *" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtCelular"
                                       promptText="Ej: 3004445566"
                                       GridPane.rowIndex="3"
                                       GridPane.columnIndex="0"/>

                            <Label text="Género *" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                            <ComboBox fx:id="cmbGenero"
                                      maxWidth="Infinity"
                                      GridPane.rowIndex="3"
                                      GridPane.columnIndex="1"/>

                            <Label text="Fecha nacimiento" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                            <DatePicker fx:id="dpFechaNacimiento"
                                        maxWidth="Infinity"
                                        GridPane.rowIndex="3"
                                        GridPane.columnIndex="2"/>

                            <Label text="Correo electrónico" GridPane.rowIndex="2" GridPane.columnIndex="3"/>
                            <TextField fx:id="txtCorreo"
                                       promptText="correo@example.com"
                                       GridPane.rowIndex="3"
                                       GridPane.columnIndex="3"/>
                        </GridPane>
                    </VBox>

                    <VBox spacing="12"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 8, 0, 0, 2);">

                        <Label text="Datos de la cita"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1f2d3d;"/>

                        <Label text="La disponibilidad se carga automáticamente al seleccionar médico/terapista y fecha. Los días festivos aparecen bloqueados en rojo."
                               wrapText="true"
                               style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>

                        <GridPane hgap="15" vgap="14">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="45"/>
                                <ColumnConstraints percentWidth="20"/>
                                <ColumnConstraints percentWidth="5"/>
                                <ColumnConstraints percentWidth="30"/>
                            </columnConstraints>

                            <Label text="Médico/Terapista *" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="cmbMedico"
                                      maxWidth="Infinity"
                                      prefHeight="40"
                                      promptText="Seleccione un médico"
                                      GridPane.rowIndex="1"
                                      GridPane.columnIndex="0"/>

                            <Label text="Fecha de cita *" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                            <TextField fx:id="txtFechaCitaVisible"
                                       editable="false"
                                       focusTraversable="false"
                                       maxWidth="Infinity"
                                       prefHeight="40"
                                       promptText="Seleccione fecha"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-border-color: #2563eb; -fx-border-width: 1.5; -fx-border-radius: 8; -fx-background-radius: 8; -fx-background-color: white;"
                                       GridPane.rowIndex="1"
                                       GridPane.columnIndex="1"/>

                            <Label text=" " GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <DatePicker fx:id="dpFechaCita"
                                        maxWidth="52"
                                        prefWidth="52"
                                        prefHeight="40"
                                        promptText=""
                                        style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-border-color: #2563eb; -fx-border-radius: 8; -fx-background-radius: 8;"
                                        GridPane.rowIndex="1"
                                        GridPane.columnIndex="2"/>

                            <Label text="Hora disponible *" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
                            <ComboBox fx:id="cmbHoraDisponible"
                                      maxWidth="Infinity"
                                      prefHeight="40"
                                      promptText="Seleccione hora"
                                      GridPane.rowIndex="1"
                                      GridPane.columnIndex="3"/>

                            <Label fx:id="lblEstadoDisponibilidad"
                                   text="Seleccione médico/terapista y fecha para cargar las horas automáticamente."
                                   wrapText="true"
                                   style="-fx-font-size: 12px; -fx-text-fill: #2563eb; -fx-font-weight: bold;"
                                   GridPane.rowIndex="2"
                                   GridPane.columnIndex="0"
                                   GridPane.columnSpan="4"/>

                            <Label text="Observación" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <TextArea fx:id="txtObservacion"
                                      promptText="Describe brevemente el motivo de la cita"
                                      prefRowCount="3"
                                      wrapText="true"
                                      GridPane.rowIndex="4"
                                      GridPane.columnIndex="0"
                                      GridPane.columnSpan="4"/>
                        </GridPane>

                        <HBox spacing="12">
                            <Region HBox.hgrow="ALWAYS"/>

                            <Button text="Confirmar cita"
                                    onAction="#agendarCita"
                                    prefWidth="180"
                                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="12"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 8, 0, 0, 2);">

                        <HBox spacing="12">
                            <Label text="Mis citas"
                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1f2d3d;"/>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Button text="Consultar mis citas"
                                    onAction="#consultarMisCitas"
                                    prefWidth="180"
                                    style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        </HBox>

                        <Label text="Cita pendiente o agendada"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1f2d3d;"/>

                        <TableView fx:id="tablaCitaPendiente" prefHeight="150">
                            <columns>
                                <TableColumn fx:id="pendienteIdColumn" text="ID" prefWidth="60"/>
                                <TableColumn fx:id="pendienteMedicoColumn" text="Médico" prefWidth="220"/>
                                <TableColumn fx:id="pendienteFechaColumn" text="Fecha" prefWidth="120"/>
                                <TableColumn fx:id="pendienteHoraColumn" text="Hora" prefWidth="100"/>
                                <TableColumn fx:id="pendienteEstadoColumn" text="Estado" prefWidth="120"/>
                                <TableColumn fx:id="pendienteObservacionColumn" text="Observación" prefWidth="350"/>
                            </columns>
                        </TableView>

                        <Label text="Historial de citas"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1f2d3d;"/>

                        <TableView fx:id="tablaHistorialCitas" prefHeight="220">
                            <columns>
                                <TableColumn fx:id="historialIdColumn" text="ID" prefWidth="60"/>
                                <TableColumn fx:id="historialMedicoColumn" text="Médico" prefWidth="220"/>
                                <TableColumn fx:id="historialFechaColumn" text="Fecha" prefWidth="120"/>
                                <TableColumn fx:id="historialHoraColumn" text="Hora" prefWidth="100"/>
                                <TableColumn fx:id="historialEstadoColumn" text="Estado" prefWidth="120"/>
                                <TableColumn fx:id="historialObservacionColumn" text="Observación" prefWidth="350"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <Label text="* Campos obligatorios"
                           style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>