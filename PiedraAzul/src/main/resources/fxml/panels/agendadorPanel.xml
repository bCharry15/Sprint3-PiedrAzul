<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.unicauca.piedraazul.controller.AgendadorPanelController"
            styleClass="dashboard-root">

    <left>
        <VBox prefWidth="250.0" spacing="16.0" styleClass="sidebar">
            <children>
                <VBox spacing="4.0">
                    <children>
                        <Label text="Piedrazul" styleClass="sidebar-title"/>
                        <Label text="Panel Agendador" styleClass="sidebar-subtitle"/>
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Button fx:id="crearCitaButton"
                                text="Crear cita"
                                onAction="#mostrarCrearCita"
                                styleClass="menu-button-active"
                                maxWidth="Infinity"/>

                        <Button fx:id="consultarCitasButton"
                                text="Consultar citas"
                                onAction="#mostrarConsultarCitas"
                                styleClass="menu-button"
                                maxWidth="Infinity"/>
                    </children>
                </VBox>

                <VBox VBox.vgrow="ALWAYS"/>

                <Button text="Cerrar sesión"
                        onAction="#logout"
                        styleClass="secondary-button"
                        maxWidth="Infinity"/>
            </children>

            <padding>
                <Insets top="24.0" right="18.0" bottom="24.0" left="18.0"/>
            </padding>
        </VBox>
    </left>

    <center>
        <VBox spacing="20.0" styleClass="content-area">
            <children>
                <VBox spacing="6.0">
                    <children>
                        <Label fx:id="tituloSeccionLabel"
                               text="Gestión de citas"
                               styleClass="top-title"/>

                        <Label fx:id="subtituloSeccionLabel"
                               text="Aquí el agendador puede registrar una nueva cita y consultar las citas de un médico por fecha."
                               styleClass="top-subtitle"/>
                    </children>
                </VBox>

                <VBox fx:id="crearCitaSection"
                      spacing="14.0"
                      styleClass="form-card">
                    <children>
                        <Label text="Crear nueva cita" styleClass="form-title"/>

                        <GridPane hgap="16.0" vgap="12.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="33.33"/>
                                <ColumnConstraints percentWidth="33.33"/>
                                <ColumnConstraints percentWidth="33.33"/>
                            </columnConstraints>

                            <children>
                                <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <children>
                                        <Label text="Tipo de documento" styleClass="field-label"/>
                                        <ComboBox fx:id="tipoDocumentoCombo" promptText="Seleccione"/>
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <children>
                                        <Label text="Número de documento" styleClass="field-label"/>
                                        <TextField fx:id="numeroDocumentoField" promptText="Ingrese documento"/>
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                    <children>
                                        <Label text="Celular" styleClass="field-label"/>
                                        <TextField fx:id="celularField" promptText="Ingrese celular"/>
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <children>
                                        <Label text="Nombres" styleClass="field-label"/>
                                        <TextField fx:id="nombresField" promptText="Ingrese nombres"/>
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <children>
                                        <Label text="Apellidos" styleClass="field-label"/>
                                        <TextField fx:id="apellidosField" promptText="Ingrese apellidos"/>
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                    <children>
                                        <Label text="Género" styleClass="field-label"/>
                                        <ComboBox fx:id="generoCombo" promptText="Seleccione"/>
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                    <children>
                                        <Label text="Fecha de nacimiento" styleClass="field-label"/>
                                        <DatePicker fx:id="fechaNacimientoPicker"/>
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                    <children>
                                        <Label text="Correo electrónico" styleClass="field-label"/>
                                        <TextField fx:id="correoField" promptText="Opcional"/>
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" GridPane.columnIndex="2" GridPane.rowIndex="2">
                                    <children>
                                        <Label text="Médico / Terapeuta" styleClass="field-label"/>
                                        <ComboBox fx:id="medicoCombo" promptText="Seleccione médico"/>
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="3">
                                    <children>
                                        <Label text="Fecha de la cita" styleClass="field-label"/>
                                        <DatePicker fx:id="fechaCitaPicker"/>
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                    <children>
                                        <Label text="Hora de la cita" styleClass="field-label"/>
                                        <ComboBox fx:id="horaCombo" promptText="Seleccione hora"/>
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" GridPane.columnIndex="2" GridPane.rowIndex="3">
                                    <children>
                                        <Label text="Observación" styleClass="field-label"/>
                                        <TextArea fx:id="observacionArea" promptText="Opcional" prefRowCount="2"/>
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>

                        <HBox spacing="12.0">
                            <children>
                                <Button text="Guardar cita"
                                        onAction="#guardarCita"
                                        styleClass="content-button"/>

                                <Button text="Limpiar formulario"
                                        onAction="#limpiarFormulario"
                                        styleClass="secondary-button"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox fx:id="consultarCitasSection"
                      spacing="14.0"
                      styleClass="form-card"
                      visible="false"
                      managed="false">
                    <children>
                        <Label text="Consultar citas por médico y fecha" styleClass="form-title"/>

                        <HBox spacing="16.0">
                            <children>
                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="Médico / Terapeuta" styleClass="field-label"/>
                                        <ComboBox fx:id="medicoBusquedaCombo" promptText="Seleccione médico" prefWidth="300.0"/>
                                    </children>
                                </VBox>

                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="Fecha" styleClass="field-label"/>
                                        <DatePicker fx:id="fechaBusquedaPicker"/>
                                    </children>
                                </VBox>

                                <VBox spacing="6.0">
                                    <children>
                                        <Label text=" " styleClass="field-label"/>
                                        <Button text="Buscar citas"
                                                onAction="#buscarCitas"
                                                styleClass="content-button"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <Label fx:id="cantidadCitasLabel" text="Cantidad de citas: 0" styleClass="count-label"/>

                        <TableView fx:id="citasTable" prefHeight="260.0">
                            <columns>
                                <TableColumn fx:id="idColumn" text="ID" prefWidth="70.0"/>
                                <TableColumn fx:id="pacienteColumn" text="Paciente" prefWidth="180.0"/>
                                <TableColumn fx:id="documentoColumn" text="Documento" prefWidth="130.0"/>
                                <TableColumn fx:id="medicoColumn" text="Médico" prefWidth="180.0"/>
                                <TableColumn fx:id="fechaColumn" text="Fecha" prefWidth="110.0"/>
                                <TableColumn fx:id="horaColumn" text="Hora" prefWidth="100.0"/>
                                <TableColumn fx:id="estadoColumn" text="Estado" prefWidth="120.0"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>