<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.unicauca.piedraazul.controller.MedicoPanelController"
            styleClass="dashboard-root">

    <left>
        <VBox prefWidth="250.0" spacing="16.0" styleClass="sidebar">
            <children>
                <VBox spacing="4.0">
                    <children>
                        <Label text="Piedrazul" styleClass="sidebar-title"/>
                        <Label text="Panel Médico" styleClass="sidebar-subtitle"/>
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Button text="Mis citas" styleClass="menu-button-active" maxWidth="Infinity"/>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <Button text="Cerrar sesión"
                        onAction="#handleLogout"
                        styleClass="logout-button"
                        maxWidth="Infinity">
                    <VBox.margin>
                        <Insets top="0.0" right="20.0" bottom="60.0" left="20.0"/>
                    </VBox.margin>
                </Button>
            </children>

            <padding>
                <Insets top="24.0" right="18.0" bottom="24.0" left="18.0"/>
            </padding>
        </VBox>
    </left>

    <center>
        <VBox spacing="20.0" styleClass="content-area">
            <children>
                <VBox spacing="6.0">
                    <children>
                        <Label fx:id="bienvenidaLabel" text="Bienvenido, médico" styleClass="top-title"/>
                        <Label text="Aquí puede consultar sus citas por fecha." styleClass="top-subtitle"/>
                    </children>
                </VBox>

                <VBox spacing="14.0" styleClass="form-card">
                    <children>
                        <Label text="Consultar mis citas" styleClass="form-title"/>

                        <HBox spacing="16.0">
                            <children>
                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="Fecha" styleClass="field-label"/>
                                        <DatePicker fx:id="fechaBusquedaPicker"/>
                                    </children>
                                </VBox>

                                <VBox spacing="6.0">
                                    <children>
                                        <Label text=" " styleClass="field-label"/>
                                        <Button text="Buscar"
                                                onAction="#buscarMisCitas"
                                                styleClass="content-button"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <Label fx:id="cantidadCitasLabel" text="Cantidad de citas: 0" styleClass="count-label"/>

                        <TableView fx:id="citasTable" prefHeight="320.0">
                            <columns>
                                <TableColumn fx:id="idColumn" text="ID" prefWidth="70.0"/>
                                <TableColumn fx:id="pacienteColumn" text="Paciente" prefWidth="220.0"/>
                                <TableColumn fx:id="documentoColumn" text="Documento" prefWidth="140.0"/>
                                <TableColumn fx:id="fechaColumn" text="Fecha" prefWidth="120.0"/>
                                <TableColumn fx:id="horaColumn" text="Hora" prefWidth="100.0"/>
                                <TableColumn fx:id="estadoColumn" text="Estado" prefWidth="120.0"/>
                                <TableColumn fx:id="observacionColumn" text="Observación" prefWidth="280.0"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>